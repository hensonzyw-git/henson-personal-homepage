---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout lang="zh" title="404 · Henson的个人站" description="页面不存在" canonicalPath="/" noindex>
  <section class="notfound">
    <div class="eyebrow">404 · Not found</div>
    <h1 class="display nf-title">这里没有内容</h1>
    <p class="nf-sub">你要找的页面不存在或已移动。回到首页继续浏览。</p>
    <div class="nf-ctas">
      <a class="btn btn-primary" href="/">返回首页</a>
      <a class="btn btn-ghost" href="/blog">去看文章</a>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound { max-width: 720px; margin: 0 auto; padding: 96px 40px 80px; }
  .nf-title { font-size: clamp(34px, 4.4vw, 52px); margin: 18px 0 0; line-height: 1.1; }
  .nf-sub { font-size: 18px; color: var(--muted); margin: 20px 0 0; }
  .nf-ctas { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 34px; }
</style>
