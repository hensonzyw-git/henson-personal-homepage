---
import { localePath, type Lang } from '../lib/i18n';
import { getAIIndex, aiUpdated, monoDate } from '../lib/content';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const p = (path: string) => localePath(lang, path);
const rows = await getAIIndex(lang);

const copy = lang === 'en'
  ? {
      eyebrow: 'AI Practice · Side Projects',
      title: 'AI you build by hand',
      intro: 'Tools, prompts, automation — and this site itself. More "artifact" than essay; the core differentiator for an AI-era PM.',
      did: 'What', how: 'How', value: 'Value',
      updated: 'Updated',
      emptyTitle: 'Empty / placeholder',
      emptyBody: 'With few entries, index cards suffice; detail pages are optional.\nMore practice · in progress',
      detail: 'View detail →',
    }
  : {
      eyebrow: 'AI 实践 · Side Projects',
      title: '动手做的 AI',
      intro: '工具、prompt、自动化，以及本网站自身。比文章更偏「作品 / 实物」—— AI 时代 PM 的核心差异化载体。',
      did: '做了什么', how: '怎么做', value: '价值 / 产出',
      updated: '最近更新',
      emptyTitle: '空态 / 占位',
      emptyBody: '条目少时仅有索引卡片，详情页可选。\n更多实践 · 内容建设中',
      detail: '查看详情 →',
    };
---
<section class="container index">
  <div class="eyebrow index-eyebrow">{copy.eyebrow}</div>
  <h1 class="display index-h1">{copy.title}</h1>
  <p class="index-intro">{copy.intro}</p>

  <div class="ai-grid grid-2">
    {rows.map((r) => (
      <div class={`ai-card ${r.entry.data.featured ? 'featured' : ''}`}>
        {r.entry.data.cardImage ? (
          <div class:list={['ai-band', r.entry.data.cardImageMode === 'phone' ? 'ai-band-phone' : 'ai-band-cover']}>
            <img src={r.entry.data.cardImage} alt={r.entry.data.title} loading="lazy" />
          </div>
        ) : (
          <div class="hatch ai-band">
            <span class="mono band-label">{r.entry.data.placeholderLabel}</span>
          </div>
        )}
        <div class="ai-card-body">
          {r.entry.data.tag && (
            <div class="ai-tag-row"><span class="pill pill-clay">{r.entry.data.tag}</span></div>
          )}
          {r.entry.data.hasDetail ? (
            <a class="ai-card-title-link" href={p(`/ai/${r.slug}`)}>
              <div class="display ai-card-title">{r.entry.data.title}</div>
            </a>
          ) : (
            <div class="display ai-card-title">{r.entry.data.title}</div>
          )}
          <div class="mono ai-updated">{copy.updated} · {monoDate(aiUpdated(r.entry))}</div>
          {r.entry.data.did && (<><div class="ai-row-label mono">{copy.did}</div><div class="ai-row-text">{r.entry.data.did}</div></>)}
          {r.entry.data.how && (<><div class="ai-row-label mono">{copy.how}</div><div class="ai-row-text">{r.entry.data.how}</div></>)}
          {r.entry.data.value && (<><div class="ai-row-label mono">{copy.value}</div><div class="ai-row-text">{r.entry.data.value}</div></>)}
          {r.entry.data.hasDetail && (
            <a class="ai-detail-link" href={p(`/ai/${r.slug}`)}>{copy.detail}</a>
          )}
        </div>
      </div>
    ))}

    <!-- dashed empty-state tile (always present per design) -->
    <div class="ai-empty">
      <span class="mono empty-tag">{copy.emptyTitle}</span>
      <span class="empty-body" set:html={copy.emptyBody.replace(/\n/g, '<br>')}></span>
    </div>
  </div>
</section>

<style>
  .index { padding-top: 64px; padding-bottom: 40px; }
  .index-eyebrow { margin-bottom: 18px; }
  .index-h1 { font-size: clamp(34px, 4.4vw, 52px); margin: 0; max-width: 20ch; line-height: 1.1; }
  .index-intro { font-size: 18px; color: var(--muted); max-width: 58ch; margin: 20px 0 0; }
  .ai-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 34px; }
  .ai-card { background: var(--surface); border: 1px solid var(--line-10); border-radius: 16px; overflow: hidden; }
  .ai-card.featured { border-color: var(--clay); }
  .ai-band { height: 150px; }
  /* cover: landscape image fills the band */
  .ai-band-cover { padding: 0; }
  .ai-band-cover img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
  /* phone: narrow device rising from the bottom of a branded backdrop (mobile apps) */
  .ai-band-phone { padding: 0; overflow: hidden; position: relative; background: linear-gradient(165deg, #efe7df 0%, #e6dccf 100%); }
  .ai-band-phone img {
    position: absolute;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: 47%;
    max-width: 240px;
    height: auto;
    border-radius: 16px 16px 0 0;
    border: 1px solid rgba(31, 30, 27, .12);
    box-shadow: 0 10px 28px rgba(31, 30, 27, .22);
  }
  .band-label { font-size: 12px; color: var(--meta); }
  .ai-card-body { padding: 26px 26px 28px; }
  .ai-tag-row { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
  .pill { display: inline-block; border-radius: 999px; padding: 3px 10px; font-size: 11px; font-family: var(--mono); }
  .pill-clay { color: #fff; background: var(--clay); }
  .ai-card-title { font-size: 23px; }
  .ai-updated { font-size: 11px; color: var(--meta); margin-top: 8px; }
  .ai-card-title-link { text-decoration: none; color: inherit; }
  .ai-card-title-link:hover .ai-card-title { color: var(--clay); }
  .ai-row-label { font-size: 13px; color: var(--meta); margin: 14px 0 4px; }
  .ai-row-label + .ai-row-text + .ai-row-label { margin-top: 12px; }
  .ai-row-text { font-size: 15px; color: var(--body-2); }
  .ai-detail-link { display: inline-block; margin-top: 18px; color: var(--clay); font-family: var(--mono); font-size: 13px; text-decoration: none; }
  .ai-detail-link:hover { text-decoration: underline; }
  .ai-empty {
    background: var(--surface);
    border: 1px dashed var(--line-16);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 330px;
    gap: 10px;
    padding: 26px;
    text-align: center;
  }
  .empty-tag { font-size: 12px; color: var(--meta); }
  .empty-body { font-size: 15px; color: var(--muted-2); }

  @media (max-width: 860px) {
    .ai-grid { grid-template-columns: 1fr; }
  }
</style>
