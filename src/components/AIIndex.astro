---
import { localePath, type Lang } from '../lib/i18n';
import { getAIIndex, monoDate } from '../lib/content';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const p = (path: string) => localePath(lang, path);
const rows = await getAIIndex(lang);

const copy = lang === 'en'
  ? {
      eyebrow: 'AI Practice · Side Projects',
      title: 'AI you build by hand',
      intro: 'Tools, prompts, automation — and this site itself. More "artifact" than essay; the core differentiator for an AI-era PM.',
      more: 'More practice · in progress',
    }
  : {
      eyebrow: 'AI 实践 · Side Projects',
      title: '动手做的 AI',
      intro: '工具、prompt、自动化，以及本网站自身。比文章更偏「作品 / 实物」—— AI 时代 PM 的核心差异化载体。',
      more: '更多实践 · 内容建设中',
    };
---
<section class="container index">
  <div class="eyebrow index-eyebrow">{copy.eyebrow}</div>
  <h1 class="display index-h1">{copy.title}</h1>
  <p class="index-intro">{copy.intro}</p>

  <div class="post-list">
    {rows.map((r) => {
      const linked = r.entry.data.hasDetail;
      const Row = linked ? 'a' : 'div';
      return (
        <Row class:list={['post-row', { 'post-row-static': !linked }]} href={linked ? p(`/ai/${r.slug}`) : undefined}>
          <div class="post-date">{monoDate(r.entry.data.date, '·')}</div>
          <div>
            {r.entry.data.tag && <span class="pill pill-clay post-kicker">{r.entry.data.tag}</span>}
            <div class="display post-title">{r.entry.data.title}</div>
            <div class="post-summary">{r.entry.data.oneLiner}</div>
          </div>
        </Row>
      );
    })}
  </div>

  <div class="ai-more">{copy.more}</div>
</section>

<style>
  .index { padding-top: 64px; padding-bottom: 40px; }
  .index-eyebrow { margin-bottom: 18px; }
  .index-h1 { font-size: clamp(34px, 4.4vw, 52px); margin: 0; max-width: 20ch; line-height: 1.1; }
  .index-intro { font-size: 18px; color: var(--muted); max-width: 58ch; margin: 20px 0 0; }
  .post-list { margin-top: 34px; border-top: 1px solid var(--line-12); }
  .post-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 32px;
    border-bottom: 1px solid var(--line-12);
    padding: 30px 18px;
    text-decoration: none;
    color: inherit;
    transition: transform .18s cubic-bezier(.2, .7, .3, 1);
    transform-origin: center;
  }
  /* hover: no background change — gentle card-select zoom (matches Writing & Latest) */
  .post-row:not(.post-row-static):hover { transform: scale(1.018); }
  .post-row-static { cursor: default; }
  .post-date { font-family: var(--mono); font-size: 12px; color: var(--meta); padding-top: 6px; }
  .post-kicker { display: inline-block; margin-bottom: 10px; }
  .pill { border-radius: 999px; padding: 3px 10px; font-size: 11px; font-family: var(--mono); }
  .pill-clay { color: #fff; background: var(--clay); }
  .post-title { font-size: 25px; line-height: 1.25; }
  .post-summary { font-size: 16px; color: var(--muted); margin-top: 9px; max-width: 62ch; }
  .ai-more {
    margin-top: 30px;
    border: 1px dashed var(--line-16);
    border-radius: 14px;
    padding: 28px;
    text-align: center;
    color: var(--muted-2);
    font-family: var(--mono);
    font-size: 13px;
  }
  @media (max-width: 860px) {
    .post-row { grid-template-columns: 1fr; gap: 8px; }
  }
</style>
