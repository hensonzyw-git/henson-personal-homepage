---
import { localePath, type Lang } from '../lib/i18n';
import { home } from '../data/home';
import { getLatest, monoDate } from '../lib/content';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const c = home[lang];
const p = (path: string) => localePath(lang, path);
const latest = await getLatest(lang, 3);
const moduleHref: Record<string, string> = {
  blog: '/blog', ai: '/ai', resume: '/resume',
};
---
<!-- HERO A · 宣言 (variant A only; A/B/C toggle stripped per spec) -->
<section class="container hero">
  <div class="eyebrow hero-eyebrow">{c.eyebrow}</div>
  <h1 class="display hero-headline" set:html={c.headline.join('<br>')}></h1>
  <p class="hero-sub">{c.sub}</p>
  <div class="hero-ctas">
    <a class="btn btn-primary" href={p('/blog')}>{c.ctaPrimary}</a>
    <a class="btn btn-ghost" href={p('/ai')}>{c.ctaSecondary}</a>
  </div>
  <div class="hero-stats-wrap">
    <div class="stat-grid grid-3">
      {c.stats.map((s) => (
        <div class="stat-tile">
          <div class="display stat-value">{s.value}</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- LATEST 最新动态 (mixed Blog + AI feed, newest 3, date-desc) -->
<section class="latest">
  <div class="container latest-inner">
    <div class="latest-head">
      <h2 class="display latest-title">{c.latest.title}</h2>
      <span class="mono latest-note">{c.latest.note}</span>
    </div>
    <p class="latest-sub">{c.latest.sub}</p>

    {latest.length === 0 ? (
      <div class="empty-state">{lang === 'en' ? 'Content in progress' : '内容建设中'}</div>
    ) : (
      <div class="latest-list">
        {latest.map((item) => {
          const Row = item.linked ? 'a' : 'div';
          return (
            <Row class:list={['latest-row', { 'latest-row-static': !item.linked }]} href={item.linked ? p(item.href) : undefined}>
              <div class="latest-meta">
                <span class={item.clay ? 'pill pill-clay' : 'pill pill-grey'}>{item.categoryLabel}</span>
                <span class="latest-date">{monoDate(item.date)}</span>
              </div>
              <div>
                <div class="display latest-row-title">{item.title}</div>
                <div class="latest-row-summary">{item.summary}</div>
              </div>
              {item.linked && <span class="latest-arrow">→</span>}
            </Row>
          );
        })}
      </div>
    )}
  </div>
</section>

<!-- MODULES 模块导航枢纽 (2×2) -->
<section class="container modules">
  <h2 class="display modules-title">{c.modulesTitle}</h2>
  <div class="module-grid grid-2">
    {c.modules.map((m) => (
      <a class="module-card lift" href={p(moduleHref[m.key])}>
        <div>
          <div class="display module-card-title">{m.title}</div>
          <div class="module-card-desc">{m.desc}</div>
        </div>
        <span class="module-arrow">→</span>
      </a>
    ))}
  </div>
</section>

<style>
  /* hero */
  .hero { padding-top: 78px; padding-bottom: 64px; }
  .hero-eyebrow { margin-bottom: 26px; }
  .hero-headline {
    font-size: clamp(40px, 6.2vw, 78px);
    line-height: 1.06;
    letter-spacing: -.01em;
    margin: 0;
    max-width: 16ch;
    text-wrap: balance;
  }
  .hero-sub {
    font-size: clamp(18px, 2vw, 21px);
    color: var(--muted);
    max-width: 600px;
    margin: 30px 0 0;
    line-height: 1.55;
  }
  .hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 38px; }
  .hero-stats-wrap { margin-top: 58px; }
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line-10);
    border: 1px solid var(--line-10);
    border-radius: 14px;
    overflow: hidden;
  }
  .stat-tile { background: var(--surface); padding: 26px 22px; }
  .stat-value { font-size: 34px; line-height: 1; }
  .stat-label { font-size: 14px; color: var(--muted-2); margin-top: 8px; }

  /* latest */
  .latest { background: var(--band); border-top: 1px solid var(--line-08); }
  .latest-inner { padding-top: 64px; padding-bottom: 64px; }
  .latest-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 8px; }
  .latest-title { font-size: 30px; margin: 0; }
  .latest-note { font-size: 12px; color: var(--meta); }
  .latest-sub { font-size: 14px; color: var(--meta); margin: 0 0 8px; }
  .latest-list { margin-top: 22px; border-top: 1px solid var(--line-12); }
  .latest-row {
    display: grid;
    grid-template-columns: 160px 1fr auto;
    gap: 28px;
    align-items: center;
    border-bottom: 1px solid var(--line-12);
    padding: 26px 0;
    text-decoration: none;
    color: inherit;
    transition: background .12s ease;
  }
  .latest-row:hover { background: rgba(255, 255, 255, .35); }
  .latest-row-static { cursor: default; }
  .latest-row-static:hover { background: transparent; }
  .latest-meta { font-family: var(--mono); font-size: 12px; color: var(--meta); display: flex; flex-direction: column; gap: 8px; align-items: flex-start; }
  .pill { display: inline-block; border-radius: 999px; padding: 2px 9px; font-size: 11px; font-family: var(--mono); }
  .pill-clay { color: #fff; background: var(--clay); }
  .pill-grey { color: var(--ink); background: var(--line-10); }
  .latest-date { color: var(--meta); }
  .latest-row-title { font-size: 22px; line-height: 1.25; }
  .latest-row-summary { font-size: 15px; color: var(--muted); margin-top: 7px; max-width: 60ch; }
  .latest-arrow { color: var(--clay); font-size: 20px; }
  .empty-state {
    margin-top: 22px;
    border: 1px dashed var(--line-16);
    border-radius: 14px;
    padding: 40px;
    text-align: center;
    color: var(--muted-2);
    font-size: 15px;
  }

  /* modules */
  .modules { padding-top: 66px; padding-bottom: 24px; }
  .modules-title { font-size: 30px; margin: 0 0 28px; }
  .module-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
  .module-card {
    background: var(--surface);
    border: 1px solid var(--line-10);
    border-radius: 16px;
    padding: 30px 28px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    text-decoration: none;
    color: inherit;
  }
  .module-card-title { font-size: 22px; }
  .module-card-desc { font-size: 15px; color: var(--muted); margin-top: 8px; max-width: 34ch; }
  .module-arrow { color: var(--clay); font-size: 20px; }
</style>
