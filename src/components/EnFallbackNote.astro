---
import { t, type Lang } from '../lib/i18n';

// Inline notice shown on a content detail page when the requested language body
// is missing and we fell back to the other language (PRD R-L4 / A-1). Per GATE 1
// every shipped entry has both languages, so this should not fire for V1 content —
// it is retained for any future single-language entry.
interface Props { lang: Lang; }
const { lang } = Astro.props;
const ui = t(lang);
---
<div class="fallback-note">
  <span class="mono fallback-tag">EN · fallback</span>
  <span>{ui.fallbackNote}</span>
</div>

<style>
  .fallback-note {
    background: var(--dark);
    color: #e6e2d6;
    border-radius: 12px;
    padding: 12px 16px;
    margin: 24px 0;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
  }
  .fallback-tag {
    font-size: 11px;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--clay);
    white-space: nowrap;
  }
</style>
