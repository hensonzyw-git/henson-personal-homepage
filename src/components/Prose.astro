---
// Editorial prose styling for rendered Markdown bodies (blog / project / ai detail).
// Mirrors the design's article typography: 18px/1.75 body, serif h2, clay-bordered
// blockquote, dark code blocks.
---
<div class="prose">
  <slot />
</div>

<script>
  // External links in article bodies open in a new tab (internal/anchor links unchanged).
  for (const a of document.querySelectorAll<HTMLAnchorElement>('.prose a[href]')) {
    try {
      if (new URL(a.href, location.href).origin !== location.origin) {
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
      }
    } catch {}
  }
</script>

<style is:global>
  .prose { font-size: 18px; line-height: 1.75; color: var(--body); }
  .prose > :first-child { margin-top: 0; }
  .prose p { margin: 0 0 24px; }
  .prose h2 {
    font-family: var(--display);
    font-weight: 600;
    font-size: 27px;
    margin: 40px 0 16px;
    line-height: 1.3;
    color: var(--ink);
    scroll-margin-top: 86px;   /* anchor jumps clear the sticky nav */
  }
  .prose h3 {
    font-family: var(--display);
    font-weight: 600;
    font-size: 21px;
    margin: 30px 0 12px;
    line-height: 1.35;
    color: var(--ink);
    scroll-margin-top: 86px;
  }
  .prose ul, .prose ol { margin: 0 0 24px; padding-left: 22px; }
  .prose li { margin-bottom: 10px; }
  /* tables: render tabular content as real tables, not flat text */
  .prose table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 0 0 24px;
    font-size: 15px;
    line-height: 1.55;
    border: 1px solid var(--line-12);
    border-radius: 10px;
    overflow: hidden;
  }
  .prose th, .prose td {
    padding: 10px 14px;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--line-12);
  }
  .prose thead th { background: var(--band); font-weight: 600; color: var(--ink); white-space: nowrap; }
  .prose tbody tr:last-child td { border-bottom: none; }
  .prose td { color: var(--body); }
  .prose strong { font-weight: 700; color: var(--ink); }
  .prose a { color: var(--clay); text-decoration: underline; }
  .prose blockquote {
    margin: 28px 0;
    padding: 4px 0 4px 20px;
    border-left: 3px solid var(--clay);
    font-family: var(--display);
    font-size: 18px;          /* match body — callout marked by the clay rule, not size */
    color: var(--ink);
    line-height: 1.7;
  }
  .prose blockquote p { margin: 0; }
  .prose pre {
    /* Shiki `css-variables` theme palette, tuned for the light-gray code surface
       (--band). Dark-on-light tokens kept warm to sit with the clay accent. */
    --astro-code-color-background: var(--band);
    --astro-code-color-text: #2b2a26;
    --astro-code-token-comment: #65625A;
    --astro-code-token-keyword: #A94E30;
    --astro-code-token-string: #5f6f2e;
    --astro-code-token-function: #8a5a2a;
    --astro-code-token-constant: #6a4d86;
    --astro-code-token-parameter: #2b2a26;
    --astro-code-token-string-expression: #5f6f2e;
    --astro-code-token-punctuation: #8A867B;
    --astro-code-token-link: #A94E30;
    margin: 0 0 24px;
    background: var(--band);
    color: #2b2a26;
    border: 1px solid var(--line-12);
    border-radius: 12px;
    padding: 20px 22px;
    overflow: auto;
    font-family: var(--mono);
    font-size: 13.5px;
    line-height: 1.6;
  }
  .prose code {
    font-family: var(--mono);
    font-size: .92em;
    background: rgba(31, 30, 27, .06);
    padding: 1px 5px;
    border-radius: 5px;
  }
  .prose pre code { background: none; padding: 0; }
  .prose hr { border: none; border-top: 1px solid var(--line-12); margin: 36px 0; }
  .prose img { max-width: 100%; border-radius: 12px; }
</style>
