---
// Editorial prose styling for rendered Markdown bodies (blog / project / ai detail).
// Mirrors the design's article typography: 18px/1.75 body, serif h2, clay-bordered
// blockquote, dark code blocks.
---
<div class="prose">
  <slot />
</div>

<style is:global>
  .prose { font-size: 18px; line-height: 1.75; color: var(--body); }
  .prose > :first-child { margin-top: 0; }
  .prose p { margin: 0 0 24px; }
  .prose h2 {
    font-family: var(--display);
    font-weight: 600;
    font-size: 27px;
    margin: 40px 0 16px;
    line-height: 1.3;
    color: var(--ink);
  }
  .prose h3 {
    font-family: var(--display);
    font-weight: 600;
    font-size: 21px;
    margin: 30px 0 12px;
    line-height: 1.35;
    color: var(--ink);
  }
  .prose ul, .prose ol { margin: 0 0 24px; padding-left: 22px; }
  .prose li { margin-bottom: 10px; }
  .prose strong { font-weight: 700; color: var(--ink); }
  .prose a { color: var(--clay); text-decoration: underline; }
  .prose blockquote {
    margin: 32px 0;
    padding: 6px 0 6px 22px;
    border-left: 3px solid var(--clay);
    font-family: var(--display);
    font-size: 21px;
    color: var(--ink);
    line-height: 1.5;
  }
  .prose blockquote p { margin: 0; }
  .prose pre {
    /* Shiki `css-variables` theme palette, tuned to the dark code surface. */
    --astro-code-color-background: var(--dark);
    --astro-code-color-text: #e6e2d6;
    --astro-code-token-comment: #8f8a7c;
    --astro-code-token-keyword: #e0996b;
    --astro-code-token-string: #b7c79a;
    --astro-code-token-function: #d8c98a;
    --astro-code-token-constant: #c9b6e0;
    --astro-code-token-parameter: #e6e2d6;
    --astro-code-token-string-expression: #b7c79a;
    --astro-code-token-punctuation: #b8b3a6;
    --astro-code-token-link: #e0996b;
    margin: 0 0 24px;
    background: var(--dark);
    color: #e6e2d6;
    border-radius: 12px;
    padding: 20px 22px;
    overflow: auto;
    font-family: var(--mono);
    font-size: 13.5px;
    line-height: 1.6;
  }
  .prose code {
    font-family: var(--mono);
    font-size: .92em;
    background: rgba(31, 30, 27, .06);
    padding: 1px 5px;
    border-radius: 5px;
  }
  .prose pre code { background: none; padding: 0; }
  .prose hr { border: none; border-top: 1px solid var(--line-12); margin: 36px 0; }
  .prose img { max-width: 100%; border-radius: 12px; }
</style>
