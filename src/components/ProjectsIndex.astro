---
import { localePath, type Lang } from '../lib/i18n';
import { getProjectIndex } from '../lib/content';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const p = (path: string) => localePath(lang, path);
const rows = await getProjectIndex(lang);

const copy = lang === 'en'
  ? { eyebrow: 'Projects', title: 'Professional product work', intro: 'Each project unfolds as "problem → decisions/tradeoffs → result → my contribution", not "I worked on X".', detail: 'View detail →', empty: 'Projects in progress' }
  : { eyebrow: '项目 · Projects', title: '职业产品工作', intro: '每个项目都按「问题 → 决策 / 取舍 → 结果 → 我的个人贡献」展开，而非「我参与了 X」。', detail: '查看详情 →', empty: '项目建设中' };
---
<section class="container index">
  <div class="eyebrow index-eyebrow">{copy.eyebrow}</div>
  <h1 class="display index-h1">{copy.title}</h1>
  <p class="index-intro">{copy.intro}</p>

  {rows.length === 0 ? (
    <div class="empty-state">{copy.empty}</div>
  ) : (
    <div class="proj-grid grid-3">
      {rows.map((r) => (
        <a class="proj-card lift" href={p(`/projects/${r.slug}`)}>
          <div>
            <div class="mono proj-tag">{r.entry.data.tag}</div>
            <div class="display proj-title">{r.entry.data.title}</div>
            <div class="proj-oneliner">{r.entry.data.oneLiner}</div>
          </div>
          <span class="proj-detail">{copy.detail}</span>
        </a>
      ))}
    </div>
  )}
</section>

<style>
  .index { padding-top: 64px; padding-bottom: 40px; }
  .index-eyebrow { margin-bottom: 18px; }
  .index-h1 { font-size: clamp(34px, 4.4vw, 52px); margin: 0; max-width: 20ch; line-height: 1.1; }
  .index-intro { font-size: 18px; color: var(--muted); max-width: 58ch; margin: 20px 0 0; }
  .proj-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 34px; }
  .proj-card {
    background: var(--surface);
    border: 1px solid var(--line-10);
    border-radius: 16px;
    padding: 28px 26px;
    min-height: 200px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-decoration: none;
    color: inherit;
  }
  .proj-tag { font-size: 11px; color: var(--meta); margin-bottom: 12px; }
  .proj-title { font-size: 22px; line-height: 1.25; }
  .proj-oneliner { font-size: 15px; color: var(--muted); margin-top: 10px; }
  .proj-detail { color: var(--clay); font-size: 18px; margin-top: 18px; }
  .empty-state {
    margin-top: 34px;
    border: 1px dashed var(--line-16);
    border-radius: 14px;
    padding: 48px;
    text-align: center;
    color: var(--muted-2);
    font-size: 16px;
  }
</style>
