---
import { t, localePath, switchLangPath, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
  canonicalPath: string; // canonical (zh) path of the current page, e.g. "/blog"
}
const { lang, canonicalPath } = Astro.props;
const ui = t(lang);
const p = (path: string) => localePath(lang, path);
---
<nav class="nav">
  <div class="container nav-inner">
    <a class="brand" href={p('/')} aria-label="Henson — home">
      <span class="logo-mark"></span>
      <span class="brand-name">Henson</span>
    </a>

    <div class="nav-links">
      <a href={p('/blog')}>{ui.nav.blog}</a>
      <a href={p('/ai')}>{ui.nav.ai}</a>
      <a href={p('/projects')}>{ui.nav.projects}</a>
      <a href={p('/resume')}>{ui.nav.resume}</a>
    </div>

    <div class="nav-right">
      <div class="lang-toggle" role="group" aria-label="Language">
        <a href={switchLangPath('zh', canonicalPath)} class={lang === 'zh' ? 'on' : ''} aria-current={lang === 'zh' ? 'true' : undefined}>中</a>
        <a href={switchLangPath('en', canonicalPath)} class={lang === 'en' ? 'on' : ''} aria-current={lang === 'en' ? 'true' : undefined}>EN</a>
      </div>
      <a class="cta" href={p('/contact')}>{ui.nav.cta}</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(238, 235, 226, .86);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line-10);
  }
  .nav-inner {
    height: 66px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .logo-mark {
    width: 13px;
    height: 13px;
    background: var(--clay);
    transform: rotate(45deg);
    display: inline-block;
    border-radius: 2px;
  }
  .brand-name {
    font-family: var(--display);
    font-size: 21px;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: .01em;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .nav-links a {
    font-size: 15px;
    color: var(--muted);
    padding: 8px 14px;
    border-radius: 8px;
    text-decoration: none;
    transition: background .12s ease, color .12s ease;
  }
  .nav-links a:hover { background: rgba(31, 30, 27, .05); color: var(--ink); }
  .nav-right { display: flex; align-items: center; gap: 14px; }
  .lang-toggle {
    display: inline-flex;
    border: 1px solid var(--line-16);
    border-radius: 999px;
    padding: 3px;
    background: rgba(255, 255, 255, .4);
  }
  .lang-toggle a {
    font-family: var(--mono);
    font-size: 12px;
    padding: 4px 11px;
    border-radius: 999px;
    text-decoration: none;
    color: var(--muted-2);
  }
  .lang-toggle a.on { background: var(--ink); color: var(--surface); }
  .cta {
    background: var(--clay);
    color: #fff;
    font-weight: 600;
    font-size: 14px;
    padding: 10px 18px;
    border-radius: 999px;
    text-decoration: none;
    transition: background .15s ease;
  }
  .cta:hover { background: var(--clay-hover); }

  @media (max-width: 860px) {
    .nav-inner { gap: 12px; flex-wrap: wrap; height: auto; padding-top: 10px; padding-bottom: 10px; }
    .nav-links { order: 3; width: 100%; justify-content: flex-start; flex-wrap: wrap; }
  }
</style>
